rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Plant Collection Rules
    match /collections/{docId} {
      function isValidPlant(data) {
        return data.userId is string && data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 200 &&
               data.image is string && data.image.size() <= 5000000; // Limit for base64 or URL
      }

      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidPlant(incoming());
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) && 
                      isValidPlant(incoming()) &&
                      incoming().userId == existing().userId;
                      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
